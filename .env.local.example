# Base URL of the backend API. Override per environment.
# Example: http://localhost:5000/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Where authentication tokens should be stored: "localStorage" or "cookie".
# (Use "cookie" only if your API issues an http-only cookie via Set-Cookie.)
NEXT_PUBLIC_AUTH_STORAGE=localStorage

# ---- Endpoint paths (override here as the backend evolves) ----
NEXT_PUBLIC_API_REGISTER=/user/create
NEXT_PUBLIC_API_LOGIN=/user/login
# Paths can contain :id and other params; the service layer substitutes them.
NEXT_PUBLIC_API_PROFILE=/user/getUserById/:id
NEXT_PUBLIC_API_UPDATE_PROFILE=/user/updateUser/:id
NEXT_PUBLIC_API_DELETE_ACCOUNT=/user/deleteUser/:id
NEXT_PUBLIC_API_UPLOAD_IMAGE=/user/uploadAvatar/:id
NEXT_PUBLIC_API_LIST_USERS=/user/getAllUser
